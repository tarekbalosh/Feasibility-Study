# ——— Server ———
PORT=8080
NODE_ENV=production

# ——— Database (Neon PostgreSQL) ———
DATABASE_URL="postgresql://USER:PASSWORD@HOST/feasibility_suite?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/feasibility_suite?sslmode=require&channel_binding=require"

# ——— JWT ———
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_change_in_production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ——— CORS ———
CORS_ORIGIN=https://your-frontend.vercel.app,http://localhost:3001

# ——— OpenAI ———
OPENAI_API_KEY=sk-your-openai-api-key-here

# ——— SMTP ———
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password
